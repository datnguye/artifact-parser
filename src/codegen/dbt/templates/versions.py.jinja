"""Discovered dbt artifact schema versions — generated by ``codegen dbt``.

Maps each artifact family to the schema versions published at
``schemas.getdbt.com``. Refreshed by ``codegen dbt --discover`` (which probes the
site); do not edit by hand.
"""

VERSIONS: dict[str, tuple[str, ...]] = {
{% for name, versions in families %}
    "{{ name }}": ({% for v in versions %}"{{ v }}", {% endfor %}),
{% endfor %}
}
